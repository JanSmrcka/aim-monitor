# PostgreSQL
DATABASE_URL="postgresql://<user>:<password>@<host>:5432/<database>?schema=public"

# Auth.js / NextAuth
AUTH_SECRET="replace-with-openssl-rand-base64-33"
AUTH_GITHUB_ID="your-github-oauth-client-id"
AUTH_GITHUB_SECRET="your-github-oauth-client-secret"

# Azure OpenAI (required for chat flow in /dashboard/new)
AZURE_RESOURCE_NAME="your-azure-openai-resource-name"
AZURE_API_KEY="your-azure-openai-api-key"
# Optional deployment/model override (defaults to gpt-5-hiring)
AZURE_CHAT_MODEL="gpt-5-hiring"

# Optional but useful in many setups
NEXTAUTH_URL="http://localhost:3000"
